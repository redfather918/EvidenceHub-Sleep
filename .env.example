# EvidenceHub Sleep — Environment Variables

# Database (SQLite for MVP local dev)
DATABASE_URL="file:./dev.db"

# Supabase (production database — required for scheduler/pipeline)
# Leave empty to use static seed-data.ts (dev mode)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Site URL (for SEO / sitemap / RSS)
NEXT_PUBLIC_SITE_URL="https://evidencehubsleep.com"

# AI Pipeline (auto-update system)
# Set AI_PROVIDER to "deepseek", "openai", or "mock" (default: mock)
AI_PROVIDER="mock"
AI_MODEL="deepseek-chat"
DEEPSEEK_API_KEY=""
OPENAI_API_KEY=""

# PubMed API (optional, increases rate limit from 3 to 10 req/s)
PUBMED_API_KEY=""

# Pipeline mode (true = dry-run, false = live)
PIPELINE_DRY_RUN="true"

# Cron authentication (required for Vercel Cron Jobs in production)
# Set to a random string; Vercel will send this as Authorization: Bearer <secret>
CRON_SECRET=""

# On-demand revalidation secret (for POST /api/revalidate)
REVALIDATE_SECRET=""

# IndexNow key (for SEO ping to Bing/Yandex)
# Place a file at public/<key>.txt with the key as content
INDEXNOW_KEY=""

# Affiliate (Job 6 — weekly, Monday)
# Amazon Product Advertising API
AMAZON_PA_ACCESS_KEY=""
AMAZON_PA_SECRET_KEY=""
AMAZON_PA_TAG=""
# iHerb
IHERB_API_KEY=""

# Newsletter (Job 7 — weekly, Friday)
# Resend API (recommended)
RESEND_API_KEY=""
NEWSLETTER_FROM_EMAIL="noreply@evidencehubsleep.com"

# TTS (future, for podcast generation)
# VOLCANO_TTS_APP_ID=""
# VOLCANO_TTS_ACCESS_TOKEN=""
